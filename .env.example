# ==========================================
# AI駆動型ナレッジ検索 文書作成支援ツール
# 環境変数設定ファイル
# ==========================================
# このファイルを .env にコピーして使用してください
# cp .env.example .env

# ----- Ollama -----
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=gemma3:4b
# 高スペック環境(GPU/RAM32GB+)では gemma3:12b に変更可
OLLAMA_TIMEOUT=120

# ----- Claude API（設定画面でclaudeモデルを選択した場合に使用） -----
# ⚠️ 本プロジェクトは「完全ローカル・閉域網動作」が前提のため、
#    未設定（空文字）がデフォルト。設定画面でclaude-*モデルが選択肢に出るのは
#    このキーを明示的に設定した場合のみ（外部送信が発生するオプトイン機能）。
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ----- Open Notebook -----
OPEN_NOTEBOOK_URL=http://open-notebook:5000

# ----- SQLite -----
SQLITE_DB_PATH=/data/sqlite/knowledge.db

# ----- Brave Search API（外部検索 / 指示時のみ） -----
BRAVE_SEARCH_API_KEY=your_brave_api_key_here
BRAVE_SEARCH_ENABLED=false

# ----- FastAPI -----
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# ----- フロントエンド -----
# ホスト公開ポートはポート台帳(997_開発ナレッジ/04_PORT_MANAGEMENT.md)の 3100-3109 に準拠
NEXT_PUBLIC_API_URL=http://localhost:3101
NEXT_PUBLIC_APP_NAME=AI Knowledge Assistant

# ----- ファイル監視クローラー -----
# 監視対象フォルダ（カンマ区切りで複数指定可）
WATCH_FOLDERS=/watch/pc_local
# ファイルサーバフォルダ（任意）
FILESERVER_FOLDERS=

# ----- セキュリティ -----
SECRET_KEY=change_this_secret_key_in_production
ALLOWED_HOSTS=localhost,127.0.0.1

# ----- Step2 DB連携（Phase3以降で設定） -----
# DB_TYPE=postgresql  # postgresql / mysql / oracle / mssql
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_USER=
# DB_PASSWORD=
# DB_READONLY=true  # 常にtrueにすること

# ----- ベクトル検索（LlamaIndex） -----
VECTOR_STORE_PATH=/data/vector_store
EMBEDDING_MODEL=intfloat/multilingual-e5-small
RAG_BACKEND=vector


# ===== 外部Ollama（Google Colab等） =====
# ngrokで公開したOllamaのURL（例: https://xxxx.ngrok-free.app）
OLLAMA_REMOTE_URL=
# 外部Ollamaのタイムアウト（秒）。Colab+大型モデルは長めに設定
OLLAMA_REMOTE_TIMEOUT=300

